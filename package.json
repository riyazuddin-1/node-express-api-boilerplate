{
  "name": "node-express-api-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Node.js Express API boilerplate with init-time database selection.",
  "type": "module",
  "bin": {
    "create-node-express-api": "./init.js"
  },
  "scripts": {
    "init": "node init.js",
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "boilerplate",
    "postgres",
    "mongo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "mongoose": "9.3.3",
    "pg": "8.20.0",
    "winston": "3.17.0"
  },
  "engines": {
    "node": ">=20"
  }
}
