NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# --- Database (Single URI per type) ---
# The app picks ONE of these based on DB_TYPE.
DATABASE_URL=postgres://user:pass@localhost:5432/node_express_api
MONGODB_URI=mongodb://localhost:27017/node_express_api

# --- App Configuration ---
DB_TYPE=postgres
JWT_SECRET=super-secret-key-change-me
